        weight: 1
        action: 2
        reward:
          currencyMin: 0
          currencyMax: 0
          ammoMin: 1
          ammoMax: 1
          removeAmmo: 0
          removeAmmoChance: 0
          removeRandomEmblem: 0
          removeRandomEmblemChance: 0
          randomElementRewards: []
          randomEmblemRewards: []
        fightEnemyPool: []
      - outcomeText: Smoke blinds you. You stumble out lighter than before.
        weight: 1
        action: 2
        reward:
          currencyMin: -10
          currencyMax: -5
          ammoMin: 0
          ammoMax: 0
          removeAmmo: 0
          removeAmmoChance: 0.5
